# py-captions-for-channels Configuration
# Copy this file to .env and customize for your environment

# ==============================================================================
# DOCKER / GPU RUNTIME
# ==============================================================================

# Docker runtime — set to "nvidia" on hosts with an NVIDIA GPU + Container Toolkit.
# Leave as "runc" (default) on CPU-only machines.  No override file needed.
# DOCKER_RUNTIME=nvidia

# Pass GPU devices into the container.  Set to "all" when using DOCKER_RUNTIME=nvidia.
# NVIDIA_VISIBLE_DEVICES=all

# ==============================================================================
# CHANNELS DVR CONFIGURATION
# ==============================================================================

# Channels DVR server base URL
# Default: http://localhost:8089
CHANNELS_DVR_URL=http://<CHANNELS_DVR_SERVER>:8089

# Full Channels DVR API URL (defaults to CHANNELS_DVR_URL)
# Only override if your DVR uses a non-standard URL. Do NOT include /api/v1.
# CHANNELS_API_URL=http://<CHANNELS_DVR_SERVER>:8089

# DVR recordings storage path (for Docker volume mount)
# This should be the path on the HOST machine where recordings are stored
# Default: /recordings
DVR_RECORDINGS_PATH=/path/to/Channels/recordings

# Path prefix mapping for distributed deployments
# When this service accesses recordings via a network share (SMB/NFS) and the
# Channels DVR API returns the server's local path, set both variables to
# translate API paths to the path reachable from this host.
#
# DVR_PATH_PREFIX: the "Media Folder" from Channels DVR Settings → General.
#   This is the root path the DVR server reports in every API file path.
# LOCAL_PATH_PREFIX: always equals DVR_MEDIA_MOUNT (the container mount path).
#   Managed automatically by the Settings UI — no need to set this separately.
#   If editing .env by hand, set it to the same value as DVR_MEDIA_MOUNT.
#
# Linux DVR at /tank/AllMedia/Channels, accessed from a remote Docker host:
#   DVR_PATH_PREFIX=/tank/AllMedia/Channels
#   LOCAL_PATH_PREFIX=/mnt/channels        ← always equals DVR_MEDIA_MOUNT; managed automatically by Settings UI
#   DVR_MEDIA_TYPE=cifs
#   DVR_MEDIA_DEVICE=//192.168.3.150/Channels
#   DVR_MEDIA_OPTS=addr=192.168.3.150,username=,password=,uid=0,gid=0,vers=3.0
#   DVR_MEDIA_MOUNT=/mnt/channels
#
# Windows DVR at D:\DVR, accessed via SMB from a Windows Docker host:
#   Store credentials first (keeps password out of files/history):
#     cmdkey /add:192.168.1.20 /user:USERNAME /pass:PASSWORD
#   Optionally map a drive letter (recommended for reliability):
#     net use Z: \\192.168.1.20\DVR /persistent:yes
#   Then set (drive letter or UNC path both work):
#   DVR_PATH_PREFIX=D:\DVR         ← path the DVR server reports (set via Setup Wizard)
#   LOCAL_PATH_PREFIX=/mnt/dvr     ← equals DVR_MEDIA_MOUNT; managed automatically
#   DVR_MEDIA_HOST_PATH=Z:/        ← drive letter, OR //192.168.1.20/DVR (any slash style)
#   DVR_MEDIA_MOUNT=/mnt/dvr
#
# Single-host (DVR and captions service on same machine): leave all commented.
# DVR_PATH_PREFIX=
# LOCAL_PATH_PREFIX=

# Docker volume mount for DVR media (used by docker-compose.yml)
# Docker mounts the volume using the local driver with configurable type/device/opts.
#
# Linux bind mount (niu — DVR and captions on same host or NFS):
#   DVR_MEDIA_TYPE=none
#   DVR_MEDIA_DEVICE=/tank/AllMedia/Channels  ← defaults to DVR_MEDIA_MOUNT if unset
#   DVR_MEDIA_OPTS=bind
#   DVR_MEDIA_MOUNT=/tank/AllMedia/Channels
#
# Windows host accessing SMB share (e.g. borgpad) — use DVR_MEDIA_HOST_PATH:
#   Store credentials first (keeps password out of files/history):
#     cmdkey /add:192.168.3.150 /user:USERNAME /pass:PASSWORD
#   Optionally map a drive letter (recommended for reliability):
#     net use Z: \\192.168.3.150\Channels /persistent:yes
#   Then set (no DVR_MEDIA_TYPE/DEVICE/OPTS needed):
#   DVR_MEDIA_HOST_PATH=Z:/        ← drive letter, OR //192.168.3.150/Channels (any slash style)
#   DVR_MEDIA_MOUNT=/mnt/channels
#   (also set DVR_PATH_PREFIX via Setup Wizard; LOCAL_PATH_PREFIX is set automatically)
#
# DVR_MEDIA_MOUNT: container path where recordings appear. LOCAL_PATH_PREFIX is always kept equal to this value by the Settings UI.
# DVR_MEDIA_TYPE=none
# DVR_MEDIA_DEVICE=
# DVR_MEDIA_OPTS=bind
# DVR_MEDIA_MOUNT=/mnt/media

# Local test directory (for development only)
# When set, uses local sample files instead of network DVR repository
# Example: /home/user/test-recordings
# Leave commented for production use
# LOCAL_TEST_DIR=

# ==============================================================================
# CHANNELWATCH CONFIGURATION
# ==============================================================================

# ChannelWatch WebSocket endpoint (usually not needed - webhooks are preferred)
# Default: ws://localhost:8501/events
CHANNELWATCH_URL=ws://<CHANNELWATCH_SERVER>:8501/events

# ==============================================================================
# EVENT SOURCE CONFIGURATION
# ==============================================================================

# Discovery mode: how the system learns about completed recordings
# "polling" - Polls Channels DVR API periodically (recommended, no setup needed)
# "webhook" - Receives webhooks from ChannelWatch (requires ChannelWatch setup)
# "mock" - Uses mock/test data (for development only)
# Default: polling
DISCOVERY_MODE=polling

# Legacy individual flags (deprecated - use DISCOVERY_MODE instead)
# USE_MOCK=false
# USE_POLLING=false  
# USE_WEBHOOK=true

# ==============================================================================
# POLLING SOURCE CONFIGURATION (when USE_POLLING=true)
# ==============================================================================

# Base polling interval in seconds
# Smart timing adjusts this: 60s near hour/:30, 300s otherwise
# Default: 120
POLL_INTERVAL_SECONDS=120

# Maximum number of recent recordings to fetch per poll
# Higher values catch more recordings but slower API calls
# Default: 50
POLL_LIMIT=50

# ==============================================================================
# WEBHOOK SERVER CONFIGURATION (when USE_WEBHOOK=true)
# ==============================================================================

# Host to bind webhook server to
# Default: 0.0.0.0 (all interfaces)
WEBHOOK_HOST=0.0.0.0

# Port for webhook server
# Default: 9000
# Configure in ChannelWatch as: json://<your-host-ip>:9000
WEBHOOK_PORT=9000

# ==============================================================================
# CAPTION PIPELINE CONFIGURATION
# ==============================================================================

# Caption embedding mode
# auto:       Automatically choose the best mode per recording (recommended):
#               - "remux" for CFR sources (OTA MPEG2, H.264 broadcast, H.265)
#               - "transcode" for VFR sources (Chrome TabCapture recordings)
# remux:      Lossless container rewrite — stream-copies video+audio, adds mov_text subtitle
#             track. Completes in seconds. Works on all clients that support embedded captions.
# transcode:  Full H.264/AAC re-encode + mux (legacy TRANSCODE_FOR_FIRETV=true behaviour).
#             Required only for VFR content (variable-frame-rate TabCapture recordings).
#             Takes 10-30 minutes per recording; use a GPU for acceptable speed.
# srt_only:   Write .srt sidecar only — no ffmpeg step. Fast; works on Apple TV / Roku / Web.
#             Fire TV and Android clients require remux or transcode mode for captions.
# Default: auto
EMBED_CAPTIONS=auto

# Legacy alias — superseded by EMBED_CAPTIONS above.
# Setting TRANSCODE_FOR_FIRETV=true is equivalent to EMBED_CAPTIONS=transcode.
# Ignored when EMBED_CAPTIONS is explicitly set.
# TRANSCODE_FOR_FIRETV=false

# Keep original recording as backup (true/false)
# true: Original .mpg file is archived as .mpg.orig after embedding
# false: Original is deleted after successful embedding (saves disk space)
# Default: true
KEEP_ORIGINAL=true

# Whisper model size for AI transcription
# Larger models are more accurate but slower and require more memory.
# tiny / tiny.en: Fastest (~5-10x realtime on CPU), lowest accuracy. Good for CPU-only testing.
# base / base.en: Fast (~4-8x realtime on CPU), acceptable accuracy.
# small / small.en: Balanced (~2-4x realtime on CPU), good accuracy. Recommended for CPU-only.
# medium / medium.en: Best quality/speed balance on GPU (default). Too slow for CPU-only use.
# large-v2 / large-v3: Best accuracy, slowest. GPU strongly recommended.
# large-v3-turbo: Faster large-v3 variant with similar quality. GPU recommended.
# distil-large-v3 / distil-large-v2: Distilled models, ~3x faster than large-v3. GPU recommended.
# Note: .en variants are English-only but slightly faster for English content.
# Default: medium
WHISPER_MODEL=medium

# Caption command (auto-detected — you should not need to set this)
# The system automatically uses the built-in embed_captions.py module which
# handles both SRT-only and transcode modes via Faster-Whisper.
# Only override if you have a custom captioning tool.
# CAPTION_COMMAND=

# Caption delay in milliseconds
# Shifts all caption timestamps forward by this amount to create a delay between audio and captions
# Useful for accessibility - some viewers prefer seeing captions slightly after hearing audio
# Range: 0-5000ms (0 = no delay, 1000 = 1 second delay)
# Default: 0
CAPTION_DELAY_MS=0

# Pipeline optimization mode (applies to both Whisper transcription and ffmpeg encoding)
# "standard": Use hardcoded parameters (conservative, use if automatic causes issues)
# "automatic": Detect encoding and optimize both Whisper and ffmpeg per recording (OTA vs TV Everywhere) (default)
# Automatic mode runs ffprobe to analyze encoding and adjusts:
#   - Whisper: beam_size and VAD thresholds for transcription quality
#   - ffmpeg: encoder presets for faster encoding (30-50% speedup on OTA content)
# See docs/AUTOMATIC_WHISPER_OPTIMIZATION.md for details
# Default: automatic
OPTIMIZATION_MODE=automatic

# Whisper device/GPU selection for AI transcription
# "auto": Automatically detect and use available GPU, fallback to CPU (recommended)
# "nvidia": Force NVIDIA GPU (CUDA) - will try even if not detected
# "amd": Force AMD GPU (ROCm) - if not supported, falls back to auto
# "intel": Force Intel GPU - if not supported, falls back to auto
# "none": Force CPU-only processing (no GPU)
# Note: GPU is typically 6-10x faster than CPU
# Default: auto
WHISPER_DEVICE=auto

# ==============================================================================
# LANGUAGE SELECTION (PRIMARY FEATURE)
# ==============================================================================

# Audio language to process (ISO 639-2/3 language code)
# Only audio tracks matching this language will be transcribed and included in output
# Common codes: eng (English), spa (Spanish), fra (French), deu (German), 
#               ita (Italian), por (Portuguese), jpn (Japanese), kor (Korean)
# For multi-language recordings, this significantly improves:
#   - Processing speed (30-50% faster - only transcribe one track)
#   - File size (smaller output - no unused audio tracks)
#   - Accuracy (Whisper optimized for specific language)
# Default: eng
AUDIO_LANGUAGE=eng

# Subtitle language to include from source (ISO code, "same", or "none")
# "same": Include native subtitles if they match audio language
# "none": Don't include native subtitles (generated captions only)
# <ISO code>: Include subtitles in specific language (e.g., "spa", "fra")
# Note: Generated captions always use audio language
# Default: same
SUBTITLE_LANGUAGE=same

# Language fallback behavior when preferred language not found
# "first": Use first available audio stream (recommended)
# "skip": Skip processing this recording entirely
# Default: first
LANGUAGE_FALLBACK=first

# Preserve all audio tracks in output (language options for viewers)
# true: Copy all audio tracks (slower encoding, preserves alternate languages)
# false: Filter to only selected language track (faster encoding, loses alternates)
# Use false to speed up multi-language recordings (e.g., English + Spanish)
# at the cost of losing alternate language tracks
# Default: true
PRESERVE_ALL_AUDIO_TRACKS=true

# Audio codec strategy for the encode step
# auto: Copy audio if source codec is MP4-compatible (ac3, eac3, aac, mp3,
#       flac, opus), otherwise re-encode to AAC.  MAJOR speed-up for OTA
#       recordings — eliminates CPU audio encoding bottleneck so GPU can
#       run at full speed.  (Recommended)
# copy: Always stream-copy audio (fastest, may fail with exotic codecs)
# aac:  Always re-encode to AAC 256 kbps (legacy, slowest — CPU-bound)
# Default: auto
AUDIO_CODEC=auto

# HARDWARE-ACCELERATED DECODING
# Uses the GPU's dedicated hardware decoder to decode input video,
# keeping frames in GPU memory for hardware encoding — avoids CPU bottleneck.
# Supports MPEG-2, H.264, and HEVC input codecs.
# Interlaced content is automatically deinterlaced on the GPU if supported.
#   "auto"  = Detect best available: NVDEC → QSV → VAAPI → CPU (recommended)
#   "cuda"  = Force NVIDIA NVDEC/CUVID decode
#   "qsv"   = Force Intel Quick Sync Video decode
#   "vaapi"  = Force VA-API decode (Intel/AMD on Linux)
#   "off"   = Always use CPU software decode
# Default: auto
HWACCEL_DECODE=auto

# GPU ENCODER SELECTION
# Which hardware encoder to use for video transcoding.
#   "auto"  = Detect best available: NVENC → QSV → VAAPI → AMF → CPU
#   "nvenc" = Force NVIDIA NVENC
#   "qsv"   = Force Intel Quick Sync Video encoder
#   "amf"   = Force AMD AMF encoder (requires AMDGPU-PRO on Linux)
#   "vaapi"  = Force VA-API encoder (Intel/AMD on Linux)
#   "cpu"   = Skip GPU encoding, always use libx264
# Default: auto
GPU_ENCODER=auto

# VIDEO ENCODING QUALITY
# Controls quality/speed/filesize tradeoff when transcoding video

# --- NVIDIA NVENC ---
# NVENC_CQ: NVIDIA GPU constant quality (0-51, lower=better quality, slower)
#   18 = Near-transparent quality (minimal loss)
#   23 = Good quality/size balance (default)
#   28 = Acceptable quality (faster encoding, smaller files)
# Default: 23
NVENC_CQ=23

# --- Intel Quick Sync Video (QSV) ---
# QSV_PRESET: Speed preset (veryfast, faster, fast, medium, slow, veryslow)
# Default: fast
QSV_PRESET=fast
# QSV_GLOBAL_QUALITY: Quality level (1-51, lower=better)
# Default: 23
QSV_GLOBAL_QUALITY=23

# --- AMD AMF ---
# AMF_QUALITY: Quality preset (speed, balanced, quality)
# Default: balanced
AMF_QUALITY=balanced
# AMF_QP: Quantization parameter (0-51, lower=better)
# Default: 23
AMF_QP=23

# --- VA-API (Intel/AMD on Linux) ---
# VAAPI_QP: Quantization parameter (0-51, lower=better)
# Default: 23
VAAPI_QP=23
# VAAPI_DEVICE: Render device path
# Default: /dev/dri/renderD128
VAAPI_DEVICE=/dev/dri/renderD128

# --- CPU (libx264) fallback ---
# X264_CRF: CPU constant rate factor (0-51, lower=better quality, slower)
#   18 = Near-transparent quality (minimal loss)
#   23 = Good quality/size balance (default)
#   28 = Acceptable quality (faster encoding, smaller files)
# Default: 23
X264_CRF=23

# Dry-run mode: if true, only print commands without executing
# Default: false
DRY_RUN=false

# Processing gate: set to false for monitoring-only mode.
# The watcher still polls the DVR and the web UI is fully functional,
# but no caption jobs are ever started (automatic or manual).
# Use this on a secondary host that monitors the same DVR without running
# Whisper (e.g. a laptop accessing a remote server over SMB with no GPU).
# Default: true
# PROCESSING_ENABLED=true

# Whitelist required mode: when true, an empty whitelist blocks all processing
# and only shows explicitly listed in the whitelist will be captioned.
# When false, an empty whitelist means "process everything".
# Default: true (strict allowlist)
# WHITELIST_REQUIRED=true

# Pipeline timeout in seconds
# For SRT only: 3600 (1 hour) is usually sufficient
# For transcoding: 7200 (2 hours) recommended for long recordings
# Default: 7200
PIPELINE_TIMEOUT=7200

# Stale execution timeout in seconds (when running jobs should be marked failed)
# Default: matches PIPELINE_TIMEOUT
STALE_EXECUTION_SECONDS=7200

# ==============================================================================
# DATA STORAGE CONFIGURATION
# ==============================================================================
# The application itself is lightweight and can be installed anywhere.
# All persistent data (database, logs, quarantine) is written under DATA_DIR.
# Point DATA_DIR to a volume with ample disk space — quarantined video files
# in particular can consume hundreds of gigabytes.
#
# Individual paths below can be overridden independently if you need to
# spread storage across multiple volumes.

# Base directory for all application data
# Default: ./data (relative to the application directory)
DATA_DIR=./data

# Docker only: host path mounted into the container as /app/data
# Change this to a volume with ample disk space (quarantine files can be huge).
# Default: ./data (relative to the repo checkout)
# HOST_DATA_DIR=/path/to/data

# ---------------------------------------------------------------------------
# Personal media library mounts (Libraries feature)
# ---------------------------------------------------------------------------
# Use the web UI "Library > Discover from Channels" to fill these in automatically.
# Up to 3 independent mounts are supported (one per NAS / server).
#
# Slot 1 (primary)
# LIBRARY_HOST_PATH=/tank/AllMedia          # host path exposed to the container
# LIBRARY_CONTAINER_PATH=/mnt/library       # container-side mount point
#
# Slot 2 (second NAS — leave unset to skip)
# LIBRARY_HOST_PATH_2=/mnt/nas2/Media
# LIBRARY_CONTAINER_PATH_2=/mnt/library2
#
# Slot 3 (third NAS — leave unset to skip)
# LIBRARY_HOST_PATH_3=/mnt/nas3/Media
# LIBRARY_CONTAINER_PATH_3=/mnt/library3

# Database file (SQLite — execution history, settings, polling cache)
# Default: ${DATA_DIR}/py_captions.db
# DB_PATH=/path/to/data/py_captions.db

# State file location (for tracking processed recordings)
# Default: ${DATA_DIR}/state.json
# STATE_FILE=/path/to/data/state.json

# Application log file (main log written alongside stdout)
# Default: ${DATA_DIR}/app.log
# LOG_FILE=/path/to/data/app.log

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
LOG_LEVEL=INFO

# ==============================================================================
# ADVANCED CONFIGURATION
# ==============================================================================

# DVR log file path (DEPRECATED — log-based source was never implemented)
# This setting will be removed in a future release.
# Default: /var/log/channels-dvr.log
# LOG_PATH=/share/CACHEDEV1_DATA/.qpkg/ChannelsDVR/channels-dvr.log

# API request timeout in seconds
# Default: 10
API_TIMEOUT=10

# Server timezone for "today" calculations
# All timestamps are stored in UTC, but calculations like job numbers reset at midnight
# in this timezone. Format: IANA timezone name (e.g., "America/New_York", "Europe/London")
# Default: System timezone
SERVER_TZ=

# Quarantine directory for orphaned files (before permanent deletion)
# ⚠️  WARNING: This directory can grow VERY large (hundreds of GB) because it
#     stores copies of quarantined video files. Point this to a volume with
#     sufficient disk space if you enable orphan cleanup.
# Default: ${DATA_DIR}/quarantine
# QUARANTINE_DIR=/path/to/data/quarantine

# How many days to keep quarantined files before permanent deletion
# Default: 30
# QUARANTINE_EXPIRATION_DAYS=30

# Orphan file cleanup (automatically remove orphaned .orig and .srt files)
# When enabled, scans for .orig and .srt files without corresponding media files
# Runs once per day when the system is idle to avoid conflicts with active processing
# true: Enable automatic cleanup
# false: Disable automatic cleanup (manual cleanup still available via UI)
# Default: false
ORPHAN_CLEANUP_ENABLED=false

# How often to run orphan cleanup (in hours)
# Default: 24 (once per day)
ORPHAN_CLEANUP_INTERVAL_HOURS=24

# How long the system must be idle before running cleanup (in minutes)
# Idle = no active pipeline executions
# Default: 15
ORPHAN_CLEANUP_IDLE_THRESHOLD_MINUTES=15

# Media file extensions recognized in your library (comma-separated, with leading dot)
# Used by orphan detection: an .srt or .orig file is considered orphaned only if
# no file with any of these extensions exists at the same path stem.
# Add extensions here if your DVR produces formats not in the default list.
# Default: .mpg,.ts,.mkv,.mp4,.avi,.wmv
MEDIA_FILE_EXTENSIONS=.mpg,.ts,.mkv,.mp4,.avi,.wmv
